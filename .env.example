# =============================================================================
# Defaults below are safe for macOS / Apple Silicon and CPU Docker (Dockerfile).
# Copy to .env and adjust. EXLA uses the XLA CPU backend on Apple Silicon (no Metal).
#
# Compile-time: set XLA_TARGET in your shell before:
#   mix deps.compile xla exla --force
# Dotenvy loads .env at app runtime; it does not recompile native xla/exla artifacts.
# =============================================================================

# Docker image for the app service (docker-compose build).
# Default matches docker-compose: ${GPU_DOCKERFILE:-Dockerfile}
# Options: Dockerfile (CPU dev), Dockerfile.test.cuda (NVIDIA + CUDA XLA — Linux), etc.
GPU_DOCKERFILE=Dockerfile

# EXLA / XLA — use cpu on Mac and for the default CPU container (compose also pins these).
# Options: cpu, cuda, cuda12, cuda13, rocm, tpu (see README)
XLA_TARGET=cpu
XLA_BUILD=false

# Optional: bind-mount host path for XLA JIT cache (default .xla_cache in project root)
# XLA_CACHE_PATH=.xla_cache

# -----------------------------------------------------------------------------
# Linux GPU training / CUDA test image (uncomment as needed)
# -----------------------------------------------------------------------------
# GPU_DOCKERFILE=Dockerfile.train.rocm
# XLA_TARGET=rocm
# XLA_BUILD=true
# ROCR_VISIBLE_DEVICES=0

# GPU_DOCKERFILE=Dockerfile.train.cuda
# XLA_TARGET=cuda12
# XLA_BUILD=false
# NVIDIA_VISIBLE_DEVICES=all

# For GPU-accelerated tests with Dockerfile.test.cuda, use a compose override that sets
# GPU_DOCKERFILE=Dockerfile.test.cuda and adds NVIDIA device reservations (README).

# Ouro Model Inference
# OURO_SEQUENCE_LENGTH: XLA-compiled context window (prompt + generation combined).
#   Higher = more memory but supports longer prompts and richer output.
#   Memory cost: ~1.5 MB per token (KV cache for 192 virtual blocks).
#   At 4096: ~6 GB KV cache + ~5.3 GB model weights ≈ 11.4 GB.
#   Model supports up to 65536 positions; default is 4096.
OURO_SEQUENCE_LENGTH=4096

# OURO_MAX_NEW_TOKENS: Maximum tokens the model will generate per call.
#   Must be less than OURO_SEQUENCE_LENGTH minus prompt token count.
#   A production RealizationPacket prompt uses ~400-500 tokens.
#   On CPU (Docker), ~150-200ms per token; 256 tokens ≈ 40-50s inference.
#   Increase to 512 or 1024 if running natively with Metal/GPU acceleration.
OURO_MAX_NEW_TOKENS=4096

# OURO_GENERATION_TIMEOUT: GenServer.call timeout for a single generate() call (ms).
#   With the sidecar backend, 60s is typically sufficient (~8 tok/s on M3).
#   With the bumblebee backend on CPU, you may need 900000 (15 min).
OURO_GENERATION_TIMEOUT=60000

# OURO_BACKEND: Which inference backend to use.
#   "sidecar"  (default) – calls the Ouro Python server via HTTP (fast, uses MPS GPU)
#   "bumblebee" – loads model in-process via Bumblebee/EXLA (legacy, much slower)
OURO_BACKEND=sidecar

# OURO_API_URL: Base URL of the Ouro inference server (sidecar backend only).
#   Start the server with: source ~/.venv-vllm-metal/bin/activate && python scripts/ouro_server.py
OURO_API_URL=http://localhost:8100

# OURO_MODEL_ID: Model identifier sent in API requests (must match what the server loaded).
OURO_MODEL_ID=ByteDance/Ouro-2.6B

# S3 / MinIO Model Store
# Enable to fetch/publish models from an S3-compatible object store.
# Training containers use --publish flag; the app pulls models on startup.
MODEL_STORE_ENABLED=false
MODEL_STORE_BUCKET=chatbot-models
S3_HOST=localhost
S3_PORT=9002
S3_SCHEME=http://
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MinIO (Docker Swarm stack only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# PostgreSQL / Atlas
# DATABASE_URL=ecto://user:pass@localhost/chat_bot_dev
POSTGRES_USER=chat_bot
POSTGRES_PASSWORD=chat_bot_dev
POSTGRES_DB=chat_bot_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Phoenix (required for production)
# SECRET_KEY_BASE=
# PHX_HOST=example.com
# PHX_SERVER=true
