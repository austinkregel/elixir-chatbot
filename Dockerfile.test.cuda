# =============================================================================
# CUDA Test Container
# =============================================================================
# Lightweight CUDA runtime image for running tests with GPU acceleration.
# Uses precompiled XLA binaries (no source build) for fast image builds.
#
# Build:
#   docker build -f Dockerfile.test.cuda -t chatbot-test:cuda .
#
# Run:
#   docker-compose -f docker-compose.yml -f docker-compose.cuda.yml \
#     run --rm -e MIX_ENV=test app mix test
# =============================================================================

# --- Stage 1: Get Erlang + Elixir from official image ---
FROM hexpm/elixir:1.18.3-erlang-27.2.4-ubuntu-noble-20250127 AS elixir-base

# --- Stage 2: CUDA runtime with Elixir ---
FROM nvidia/cuda:12.9.1-devel-ubuntu24.04

COPY --from=elixir-base /usr/local /usr/local

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    XLA_TARGET=cuda12 \
    XLA_BUILD=false \
    DEBIAN_FRONTEND=noninteractive

    RUN apt-get update && apt-get install -y --no-install-recommends --allow-change-held-packages \
    git curl wget ca-certificates build-essential inotify-tools \
    cuda-nvcc-12-9 \
    python3 python3-numpy \
    unzip zip xxd \
    libnccl2 libnccl-dev \
    libnvshmem3-cuda-12 erlang-dev lld-18 clang-18 \
    && ln -sf /usr/bin/clang-18 /usr/bin/clang \
    && ln -sf /usr/bin/clang++-18 /usr/bin/clang++ \
    && ln -sf /usr/bin/ld.lld-18 /usr/bin/ld.lld \
    && rm -rf /var/lib/apt/lists/*

    # Bazel 7.7.0 required for XLA source builds
RUN wget -q https://github.com/bazelbuild/bazel/releases/download/7.7.0/bazel-7.7.0-linux-x86_64 \
      -O /usr/local/bin/bazel \
    && chmod +x /usr/local/bin/bazel

WORKDIR /app

RUN mix local.hex --force && mix local.rebar --force

COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY scripts/exla_preflight.sh /app/scripts/exla_preflight.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["entrypoint.sh"]
