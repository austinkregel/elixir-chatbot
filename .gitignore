# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Test-generated memory and knowledge files
/test/memory/
/test/knowledge/


# Ignore package tarball (built via "mix hex.build").
chat_bot-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/


### Elixir ###
/_build
/cover
/deps
/doc
/.fetch
erl_crash.dump
*.ez
*.beam
/config/*.secret.exs
.elixir_ls/

### Elixir Patch ###

### Phoenix ###
# gitignore template for Phoenix projects
# website: http://www.phoenixframework.org/
#
# Recommended template: Elixir.gitignore

# Temporary files
/tmp

# Static artifacts
/node_modules
/assets/node_modules

# Since we are building assets from web/static,
# we ignore priv/static. You may want to comment
# this depending on your deployment strategy.
/priv/static/

# Installer-related files
/installer/_build
/installer/tmp
/installer/doc
/installer/deps

.venv
.env
.cursor


apps/*/cover/

apps/world/priv/training_worlds/*

# Runtime memory and knowledge stores (contain conversation data)
apps/*/priv/memory/*
apps/*/test/memory/
apps/*/test/knowledge/
apps/*/test/data/

# Encrypted credentials (API keys, secrets)
apps/brain/priv/secrets/
!apps/brain/priv/secrets/.gitkeep
apps/brain/priv/evaluation/
!apps/brain/priv/evaluation/.gitkeep

!apps/brain/priv/evaluation/results/.gitkeep

*.term

# Tree-sitter grammar sources (cloned at build time via Makefile)
/vendor/tree-sitter-grammars/

# Compiled tree-sitter shared libraries (built via `make grammars`)
apps/brain/priv/code/grammars/*.so
apps/*/priv/static/*
apps/*/priv/static/*

.xla_cache/
apps/world/test/training_worlds/

apps/brain/priv/ml_models/ouro/
apps/brain/test/brain/ml/lexicon/
apps/brain/test/brain/ml_models/
apps/brain/data/
apps/brain/priv/*

data/
.vscode/
.idea/
